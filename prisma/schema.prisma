// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user/contact. Stores both business owners (Clerk users) and
/// WhatsApp contacts (phone numbers) as string IDs.
model User {
  id           String   @id @db.Text
  name         String
  customName   String?  @map("custom_name")
  whatsappName String?  @map("whatsapp_name")
  lastActive   DateTime @default(now()) @map("last_active")

  // Relations
  sentMessages     Message[]     @relation("sentMessages")
  receivedMessages Message[]     @relation("receivedMessages")
  groupsOwned      ChatGroup[]   @relation("GroupOwner")
  groupMemberships GroupMember[]
  settings         UserSettings?
  apiKeys          ApiKey[]

  @@map("users")
}

/// Messages exchanged between a business owner (Clerk user) and WhatsApp contacts.
model Message {
  id          String    @id @db.Text
  senderId    String    @map("sender_id")
  receiverId  String    @map("receiver_id")
  content     String
  timestamp   DateTime  @default(now())
  isSentByMe  Boolean   @default(false) @map("is_sent_by_me")
  messageType String    @default("text") @map("message_type")
  mediaData   Json?     @map("media_data")
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")

  // Relations
  sender   User @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId], name: "idx_messages_sender")
  @@index([receiverId], name: "idx_messages_receiver")
  @@index([timestamp(sort: Desc)], name: "idx_messages_timestamp")
  @@index([isRead], name: "idx_messages_is_read")
  @@index([senderId, receiverId, timestamp(sort: Desc)], name: "idx_messages_conversation")
  @@map("messages")
}

/// Broadcast group owned by a business user.
model ChatGroup {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @map("owner_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  // Relations
  owner   User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members GroupMember[]

  @@index([ownerId], name: "idx_chat_groups_owner_id")
  @@map("chat_groups")
}

/// Member of a broadcast group, pointing to a WhatsApp contact in `users`.
model GroupMember {
  id      String   @id @default(uuid()) @db.Uuid
  groupId String   @map("group_id") @db.Uuid
  userId  String   @map("user_id")
  addedAt DateTime @default(now()) @map("added_at")

  group ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId], name: "group_members_group_id_user_id_key")
  @@index([groupId], name: "idx_group_members_group_id")
  @@index([userId], name: "idx_group_members_user_id")
  @@map("group_members")
}

/// Per-business user WhatsApp and webhook configuration.
model UserSettings {
  id                String   @id @db.Text
  accessToken       String?  @map("access_token")
  phoneNumberId     String?  @map("phone_number_id")
  businessAccountId String?  @map("business_account_id")
  verifyToken       String?  @map("verify_token")
  webhookToken      String?  @map("webhook_token")
  apiVersion        String   @default("v23.0") @map("api_version")
  webhookVerified   Boolean  @default(false) @map("webhook_verified")
  accessTokenAdded  Boolean  @default(false) @map("access_token_added")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  // Additional fields used by the UI
  phoneNumber String? @map("phone_number")
  fullName    String? @map("full_name")

  // Relations
  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@unique([webhookToken], name: "user_settings_webhook_token_key")
  @@index([phoneNumberId], name: "idx_user_settings_phone_number_id")
  @@index([webhookToken], name: "idx_user_settings_webhook_token")
  @@index([businessAccountId], name: "idx_user_settings_business_account_id")
  @@map("user_settings")
}

/// API Keys for external API access to WhatsApp Cloud features
model ApiKey {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Text
  name         String // User-friendly name for the API key
  key          String    @unique @db.Text // The actual API key (hashed)
  encryptedKey String?   @map("encrypted_key") @db.Text // Encrypted version for reveal functionality
  prefix       String    @db.Text // First 8 characters for display (e.g., "wc_live_")
  lastUsed     DateTime? @map("last_used")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @map("updated_at")
  isActive     Boolean   @default(true) @map("is_active")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_api_keys_user_id")
  @@index([key], name: "idx_api_keys_key")
  @@index([isActive], name: "idx_api_keys_is_active")
  @@map("api_keys")
}
