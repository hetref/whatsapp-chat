{
    "name": "whatsapp-monorepo",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "npm run dev --workspace @repo/web",
        "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
        "dev:web": "npm run dev --workspace @repo/web",
        "dev:api": "npm run dev --workspace @repo/api",
        "build": "npm run build --workspace @repo/web",
        "start:web": "npm run start --workspace @repo/web",
        "start:api": "npm run start --workspace @repo/api",
        "lint": "npm run lint --workspace @repo/web",
        "db:generate": "npm run generate --workspace @repo/db",
        "db:migrate:dev": "npm run migrate:dev --workspace @repo/db",
        "db:migrate:deploy": "npm run migrate:deploy --workspace @repo/db"
    },
    "devDependencies": {
        "baseline-browser-mapping": "^2.10.38",
        "concurrently": "^9.2.1",
        "shadcn": "^4.5.0"
    }
}
